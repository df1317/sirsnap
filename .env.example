# Example environment variables for local development
# Copy this file to .dev.vars and fill in your actual values

# Required: Your Slack app's signing secret
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Optional: Your Slack bot token (starts with xoxb-)
# Required for some features like posting messages
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Optional: Slack Custom Profile Field IDs for roles and CDTs
# You can find these by calling the users.profile.get API endpoint
# for a user who has these fields set, and looking at the "fields" object keys.
# They will look something like "Xf040HCJKNJZ".
SLACK_PROFILE_FIELD_CDT=your_cdt_field_id_here
SLACK_PROFILE_FIELD_ROLE=your_role_field_id_here